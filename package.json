{
  "name": "devtools-local",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "lint": "eslint . --ext .ts,.vue",
    "typecheck": "vue-tsc --noEmit"
  },
  "dependencies": {
    "crypto-js": "^4.2.0",
    "dayjs": "^1.11.13",
    "jwt-decode": "^4.0.0",
    "naive-ui": "^2.42.0",
    "qrcode": "^1.5.4",
    "vue": "^3.5.13",
    "vue-router": "^4.6.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.2",
    "@types/crypto-js": "^4.2.2",
    "@types/qrcode": "^1.5.6",
    "@vitejs/plugin-vue": "^5.2.4",
    "@vue/tsconfig": "^0.8.1",
    "eslint": "^9.35.0",
    "eslint-plugin-vue": "^10.4.0",
    "jsdom": "^27.0.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^6.4.1",
    "vitest": "^3.2.4",
    "vue-tsc": "^2.2.12"
  }
}
